# Rumbadoo — Variables de entorno para Vercel

# 1. Crea una cuenta gratis en https://turso.tech
# 2. Instala la CLI: npm install -g @libsql/client  (o usa el dashboard)
# 3. Crea una base de datos:
#    turso db create rumbadoo
# 4. Obtén la URL y el token:
#    turso db show rumbadoo --url
#    turso db tokens create rumbadoo
# 5. Agrega estas variables en Vercel (Project Settings > Environment Variables)

TURSO_DATABASE_URL=libsql://rumbadoo-nombre.turso.io
TURSO_AUTH_TOKEN=eyJ...
